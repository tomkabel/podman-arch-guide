# ============================================
# Single-Node Stack Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!
# ============================================

# ============================================
# Application Settings
# ============================================
APP_ENV=production
APP_DEBUG=false
APP_NAME=single-node-app
APP_URL=https://example.com

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
POSTGRES_USER=appuser
POSTGRES_PASSWORD=change_this_to_secure_random_password_32chars
POSTGRES_DB=appdb
POSTGRES_HOST=postgres-db
POSTGRES_PORT=5432

# Database connection URL (optional, some apps prefer this)
DATABASE_URL=postgresql://appuser:${POSTGRES_PASSWORD}@postgres-db:5432/appdb

# ============================================
# Cache Configuration (Redis)
# ============================================
REDIS_PASSWORD=change_this_to_secure_random_password_32chars
REDIS_HOST=redis-cache
REDIS_PORT=6379

# Redis connection URL
REDIS_URL=redis://:${REDIS_PASSWORD}@redis-cache:6379/0

# ============================================
# Nginx Configuration
# ============================================
NGINX_WORKER_PROCESSES=auto
NGINX_WORKER_CONNECTIONS=1024
NGINX_CLIENT_MAX_BODY_SIZE=64M
NGINX_KEEPALIVE_TIMEOUT=65

# SSL/TLS Configuration
SSL_CERT_PATH=/etc/nginx/certs/cert.pem
SSL_KEY_PATH=/etc/nginx/certs/key.pem
SSL_DHPARAM_PATH=/etc/nginx/certs/dhparam.pem

# ============================================
# Backup Configuration
# ============================================
# Local backup settings
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *

# Optional: S3-compatible backup storage
BACKUP_S3_BUCKET=my-backup-bucket
BACKUP_AWS_ACCESS_KEY=your_access_key_here
BACKUP_AWS_SECRET_KEY=your_secret_key_here
BACKUP_S3_ENDPOINT=https://s3.example.com

# ============================================
# Monitoring & Logging
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json
ENABLE_METRICS=true
METRICS_PORT=9090

# ============================================
# Security Settings
# ============================================
# Session/encryption keys (generate strong random values)
APP_KEY=base64:generate_random_32_byte_key_here
JWT_SECRET=generate_random_jwt_secret_here

# ============================================
# Resource Limits (optional overrides)
# ============================================
# NGINX_CPU_LIMIT=0.5
# NGINX_MEMORY_LIMIT=256M
# APP_CPU_LIMIT=0.5
# APP_MEMORY_LIMIT=256M
# POSTGRES_CPU_LIMIT=1.0
# POSTGRES_MEMORY_LIMIT=1G
# REDIS_CPU_LIMIT=0.5
# REDIS_MEMORY_LIMIT=512M
