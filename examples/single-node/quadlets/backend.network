# Quadlet Network File for Backend Network
# Place in ~/.config/containers/systemd/ or /etc/containers/systemd/

[Network]
NetworkName=backend
Driver=bridge
Internal=true

# IPAM configuration
Subnet=172.20.2.0/24
Gateway=172.20.2.1

# Internal network - no external access
# Only containers on this network can communicate

# Labels
Label=app=single-node-stack
Label=network=backend
